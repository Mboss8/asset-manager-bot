# Runtime
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Redis
REDIS_URL=redis://localhost:6380
REDIS_ENABLED=true
REDIS_KEY_PREFIX=tgops:

# Telegram Bot API
TELEGRAM_BOT_TOKEN=0000000000:replace_with_botfather_token

# Webhook mode for cloud deployment.
# If this variable is set, the bot uses webhook mode.
# If it is empty, the bot falls back to long polling for local development.
TELEGRAM_WEBHOOK_URL=https://your-service.example.com/telegram/webhook
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace_with_random_A-Za-z0-9_-_secret
TELEGRAM_DROP_PENDING_UPDATES=false

# Broadcast fallback targets. Prefer registering groups through the bot UI later.
TELEGRAM_GROUP_ID=
TELEGRAM_CHANNEL_ID=

# Digest schedule
DIGEST_HOUR=9
DIGEST_MINUTE=0
